  },
  "homepage": "https://github.com/DefalterXD/Webpack-Template#readme",
  "devDependencies": {
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.6",
    "style-loader": "^4.0.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  }
